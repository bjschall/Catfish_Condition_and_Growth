##All values should be positive, because it is measure of growth as a % of previous radius size
##Use the code below the loop to identify where the NA values are and what their ID numbers are
ID2<-unique(BC_inc$ID)
new<-data.frame(matrix(ncol = 0, nrow = 0))
yrs<-seq(2017,2025,1) #CCF 2017-2023 are tested and good! 
for(i in yrs)
  for(j in 1:length(ID2)){
  x<-filter(BC_inc, Year==i & ID==ID2[j])
  y<-data.frame(vals=replace(x$BCLen, seq_along(x$BCLen) >= which(x$BCLen < cummax(x$BCLen))[1], NA))
  y$j<-rep(j,length(y$vals))
  y$i<-rep(i, length(y$vals))
  new<-rbind(new, y)
}

