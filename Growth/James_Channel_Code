############ Age #############
#Prior Prediction
priors <- tibble(a = rnorm(300, 5, 1),
                 b = rnorm(300, -0.4, 0.1),
                 sigma = rexp(300, .1),
                 sim = 1:300)

# combine and simulate
prior_and_x <- priors %>% expand_grid(Age = seq(2,9,1)) %>%    # combine priors and x's
  mutate(mu = exp(a + b*Age),                              # create new column call it mu- simulate regressions
         y = rgamma(nrow(.), mu, sigma))             # new column called y simulate data (e.g., y_rep)

# plot
prior_and_x %>% 
  ggplot(aes(x = Age, y = mu, group = sim)) + 
  geom_point() +
  labs(y = "sim")

##Implement the model
get_prior(Increment_Perc ~ Annuli_Age + (1|YearID),
          family = Gamma(link="log"),
          data=filter(mod.data, Annuli_Age>1&Annuli_Age<10))

ccf.age<-brm(Increment_Perc ~ Annuli_Age + (1|YearID),
          family = Gamma(link="log"), 
          data = filter(mod.data, Annuli_Age>1&Annuli_Age<10), 
          prior = c(prior(normal(5, 1), class = "Intercept"),
                    prior(normal(-0.4, 0.1), class = "b"),
                    prior(exponential(1), class="sd", group="YearID"),
                    prior(exponential(.1), class="shape")),
          file = "Age_model.rds",
          seed = 24,
          file_refit = "on_change",
          save_pars = save_pars(all = TRUE),
          iter = 2000, chains = 4, cores = 6)

summary(ccf.age)
plot(ccf.age)
plot(conditional_effects(ccf.age),points=T)
pp_check(ccf.age)
bayes_R2(ccf.age)
#options(future.globals.maxSize = 2e9)
loo_ccf.age <- loo(ccf.age, moment_match = T, reloo=T)




#Sensitivity model
ccf.age.sens<-brm(Increment_Perc ~ Annuli_Age + (1|YearID),
                family = Gamma(link="log"), 
                data = filter(mod.data, Annuli_Age>1&Annuli_Age<10), 
                prior = c(prior(normal(5, 2), class = "Intercept"),
                          prior(normal(-0.4, 0.2), class = "b"),
                          prior(exponential(0.5), class="sd", group="YearID"),
                          prior(exponential(0.05), class="shape")),
                file = "Age_model_sens.rds",
                seed = 24,
                file_refit = "on_change",
                iter = 2000, chains = 4, cores = 6)
summary(ccf.age.sens)

#Compare estimates from model and sensitivity - Percent difference
(posterior_summary(ccf.age)[1,1]-posterior_summary(ccf.age.sens)[1,1])/posterior_summary(ccf.age)[1,1]*100 #intercept
(posterior_summary(ccf.age)[2,1]-posterior_summary(ccf.age.sens)[2,1])/posterior_summary(ccf.age)[2,1]*100 #slope
(posterior_summary(ccf.age)[3,1]-posterior_summary(ccf.age.sens)[3,1])/posterior_summary(ccf.age)[3,1]*100 #Random intercept
(posterior_summary(ccf.age)[4,1]-posterior_summary(ccf.age.sens)[4,1])/posterior_summary(ccf.age)[4,1]*100 #shape

