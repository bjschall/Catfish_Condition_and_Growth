BC_bs %>% group_by(Year, River) %>% summarize(n=length(Spp))
BC_calc_bs <- BC_bs %>% 
  mutate(YearID = paste(Year,ID, sep="_")) %>% 
  pivot_longer(cols=c(Annuli_1:Annuli_9),
               names_to=c("Age"),
               values_to="Annuli_measurement") %>% 
  separate(Age, c("name1", "Annuli_Age"), sep="_") %>%
  select(-name1) %>% 
  mutate(Annuli_Age = as.numeric(Annuli_Age)) %>% 
  mutate(BCLen = round(Annuli_measurement/Spine_Radius*Length), 
         GrowthYear = Year-Consensus_Age+Annuli_Age-1) %>% 
  filter(!is.na(BCLen))%>% 
  group_by(YearID) %>% 
  filter(max(Annuli_Age)==Consensus_Age); BC_calc_bs

#calculate growth increment by year
BC_inc_bs <- BC_calc_bs %>% 
  group_by(YearID) %>% 
  arrange(YearID, Annuli_Age) %>% 
  mutate(Increment = ifelse(Annuli_Age==1,BCLen,ifelse(BCLen - lag(BCLen, default = first(BCLen))>0,BCLen - lag(BCLen, default = first(BCLen)),NA)),
         Increment_Perc = 100*(Annuli_measurement - lag(Annuli_measurement, default = first(Annuli_measurement)))/lag(Annuli_measurement, default = first(Annuli_measurement))) %>% 
  group_by(Year,ID) %>% 
  arrange(Year,ID, Annuli_Age); BC_inc_bs


