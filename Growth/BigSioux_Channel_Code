############ Age #############
#Prior Prediction
priors <- tibble(a = rnorm(300, 5, 1),
                 b = rnorm(300, -0.4, 0.1),
                 sigma = rexp(300, .1),
                 sim = 1:300)

# combine and simulate
prior_and_x <- priors %>% expand_grid(Age = seq(2,9,1)) %>%    # combine priors and x's
  mutate(mu = exp(a + b*Age),                              # create new column call it mu- simulate regressions
         y = rgamma(nrow(.), mu, sigma))             # new column called y simulate data (e.g., y_rep)

# plot
prior_and_x %>% 
  ggplot(aes(x = Age, y = mu, group = sim)) + 
  geom_point() +
  labs(y = "sim")

##Implement the model
get_prior(Increment_Perc ~ Annuli_Age + (1|YearID),
          family = Gamma(link="log"),
          data=filter(mod.data_bs, Annuli_Age>1&Annuli_Age<10))

m.age_bs<-brm(Increment_Perc ~ Annuli_Age + (1|YearID),
          family = Gamma(link="log"), 
          data = filter(mod.data_bs, Annuli_Age>1&Annuli_Age<10), 
          prior = c(prior(normal(5, 1), class = "Intercept"),
                    prior(normal(-0.4, 0.1), class = "b"),
                    prior(exponential(1), class="sd", group="YearID"),
                    prior(exponential(.1), class="shape")),
          file = "Age_model_BigSioux.rds",
          seed = 24,
          save_pars = save_pars(all = TRUE),
          file_refit = "on_change",
          iter = 2000, chains = 4, cores = 6)

summary(m.age_bs)
plot(m.age_bs)
plot(conditional_effects(m.age_bs),points=T)
pp_check(m.age_bs)
bayes_R2(m.age_bs)
options(future.globals.maxSize = 1e9)
loo.age_bs <- loo(m.age_bs, moment_match = T, reloo=T)

#Sensitivity model
m.age_bs.sens<-brm(Increment_Perc ~ Annuli_Age + (1|YearID),
                family = Gamma(link="log"), 
                data = filter(mod.data_bs, Annuli_Age>1&Annuli_Age<10), 
                prior = c(prior(normal(5, 2), class = "Intercept"),
                          prior(normal(-0.4, 0.2), class = "b"),
                          prior(exponential(0.5), class="sd", group="YearID"),
                          prior(exponential(0.05), class="shape")),
                file = "Age_model_BigSioux_sens.rds",
                seed = 24,
                file_refit = "on_change",
                iter = 2000, chains = 4, cores = 6)
summary(m.age_bs.sens)

#Compare estimates from model and sensitivity - Percent difference
(posterior_summary(m.age_bs)[1,1]-posterior_summary(m.age_bs.sens)[1,1])/posterior_summary(m.age_bs)[1,1]*100 #intercept
(posterior_summary(m.age_bs)[2,1]-posterior_summary(m.age_bs.sens)[2,1])/posterior_summary(m.age_bs)[2,1]*100 #slope
(posterior_summary(m.age_bs)[3,1]-posterior_summary(m.age_bs.sens)[3,1])/posterior_summary(m.age_bs)[3,1]*100 #Random intercept
(posterior_summary(m.age_bs)[4,1]-posterior_summary(m.age_bs.sens)[4,1])/posterior_summary(m.age_bs)[4,1]*100 #shape

