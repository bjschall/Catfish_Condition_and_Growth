flows_bs2 <-flows_bs %>% 
  select(GrowthYear, Median_Disch) %>% 
  mutate(Median_std = (Median_Disch-mean(unique(Median_Disch)))/sd(unique(Median_Disch)),
         GDD = BigSiouxGDD$`max(cumulativeGDD)`,
         GDD_std = (GDD-mean(GDD))/sd(GDD))

mod.data_bs<-full_join(mod.dat_bs, flows_bs2, by="GrowthYear"); mod.data_bs

names(mod.data_bs)

mod.data_bs %>%
  group_by(GrowthYear, Annuli_Age) %>% 
