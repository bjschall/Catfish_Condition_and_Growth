#Prior Prediction
priors <- tibble(a = rnorm(300, 5, 1),
                 b = rnorm(300, -0.4, 0.1),
                 sigma = rexp(300, 0.1),
                 sim = 1:300)

# combine and simulate
prior_and_x <- priors %>% expand_grid(Age = seq(2,9,1)) %>%    # combine priors and x's
  mutate(mu = exp(a + b*Age),                              # create new column call it mu- simulate regressions
         y = rgamma(nrow(.), mu, sigma))             # new column called y simulate data (e.g., y_rep)

# plot
prior_and_x %>% 
  ggplot(aes(x = Age, y = mu, group = sim)) + 
  geom_point() +
  labs(y = "sim")

##Implement the model
get_prior(Increment_Perc ~ Annuli_Age + (1|YearID),
          family = Gamma(link="log"),
          data=filter(mod.data_fhc, Annuli_Age>1&Annuli_Age<10))

fhc.age<-brm(Increment_Perc ~ Annuli_Age + (1|YearID),
          family = Gamma(link="log"), 
          data = filter(mod.data_fhc, Annuli_Age>1&Annuli_Age<10), 
          prior = c(prior(normal(5, 1), class = "Intercept"),
                    prior(normal(-0.4, 0.1), class = "b"),
                    prior(exponential(1), class="sd", group="YearID"),
                    prior(exponential(.1), class="shape")),
          file = "Age_model_FHC.rds",
          seed = 24,
          save_pars = save_pars(all = TRUE),
          file_refit = "on_change",
          iter = 2000, chains = 4, cores = 6)

summary(fhc.age)
plot(fhc.age)
plot(conditional_effects(fhc.age),points=T)
pp_check(fhc.age)
bayes_R2(fhc.age)


#Sensitivity model
fhc.age.sens<-brm(Increment_Perc ~ Annuli_Age + (1|YearID),
                family = Gamma(link="log"), 
                data = filter(mod.data_fhc, Annuli_Age>1&Annuli_Age<10), 
                prior = c(prior(normal(5, 2), class = "Intercept"),
                          prior(normal(-0.4, 0.2), class = "b"),
                          prior(exponential(0.5), class="sd", group="YearID"),
                          prior(exponential(0.05), class="shape")),
                file = "Age_model_FHC_sens.rds",
                seed = 24,
                save_pars = save_pars(all = TRUE),
                file_refit = "on_change",
                iter = 2000, chains = 4, cores = 6)
summary(fhc.age.sens)

#Compare estimates from model and sensitivity - Percent difference
(posterior_summary(fhc.age)[1,1]-posterior_summary(fhc.age.sens)[1,1])/posterior_summary(fhc.age)[1,1]*100 #intercept
(posterior_summary(fhc.age)[2,1]-posterior_summary(fhc.age.sens)[2,1])/posterior_summary(fhc.age)[2,1]*100 #slope
(posterior_summary(fhc.age)[3,1]-posterior_summary(fhc.age.sens)[3,1])/posterior_summary(fhc.age)[3,1]*100 #Random intercept
(posterior_summary(fhc.age)[4,1]-posterior_summary(fhc.age.sens)[4,1])/posterior_summary(fhc.age)[4,1]*100 #shape

